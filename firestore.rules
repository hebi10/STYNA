rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocument(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function isActiveAccount() {
      return isSignedIn() &&
        exists(userDocument(request.auth.uid)) &&
        get(userDocument(request.auth.uid)).data.get('status', '') == 'active';
    }

    function hasAdminClaim() {
      return isSignedIn() &&
        (request.auth.token.get('admin', false) == true ||
          request.auth.token.get('role', '') == 'admin');
    }

    function isStrictAdmin() {
      return isActiveAccount() &&
        hasAdminClaim() &&
        get(userDocument(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function isAdmin() {
      return isStrictAdmin();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isActiveOwner(userId) {
      return isActiveAccount() && request.auth.uid == userId;
    }

    function isNonEmptyStringAtMost(value, maxLength) {
      return value is string &&
        value.size() >= 1 &&
        value.size() <= maxLength;
    }

    function isOptionalNonEmptyStringAtMost(data, field, maxLength) {
      return !data.keys().hasAny([field]) ||
        isNonEmptyStringAtMost(data[field], maxLength);
    }

    function isValidQnAImages(images) {
      return images is list &&
        images.size() <= 5 &&
        (images.size() < 1 || isNonEmptyStringAtMost(images[0], 2048)) &&
        (images.size() < 2 || isNonEmptyStringAtMost(images[1], 2048)) &&
        (images.size() < 3 || isNonEmptyStringAtMost(images[2], 2048)) &&
        (images.size() < 4 || isNonEmptyStringAtMost(images[3], 2048)) &&
        (images.size() < 5 || isNonEmptyStringAtMost(images[4], 2048));
    }

    function userCreateAllowedKeys() {
      return [
        'id',
        'email',
        'name',
        'displayName',
        'phone',
        'phoneNumber',
        'birth',
        'birthDate',
        'gender',
        'termsAgree',
        'privacyAgree',
        'marketingAgree',
        'marketingAgreed',
        'address',
        'addresses',
        'profileImage',
        'preferences',
        'status',
        'role',
        'createdAt',
        'updatedAt'
      ];
    }

    function userUpdateAllowedKeys() {
      return [
        'email',
        'name',
        'displayName',
        'phone',
        'phoneNumber',
        'birth',
        'birthDate',
        'gender',
        'marketingAgree',
        'marketingAgreed',
        'address',
        'addresses',
        'profileImage',
        'preferences',
        'updatedAt'
      ];
    }

    function isValidSelfUserCreate(userId) {
      return isOwner(userId) &&
        request.resource.data.keys().hasOnly(userCreateAllowedKeys()) &&
        request.resource.data.keys().hasAll([
          'id',
          'email',
          'name',
          'status',
          'role',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.id == userId &&
        request.resource.data.email is string &&
        request.auth.token.get('email', '') != '' &&
        request.resource.data.email == request.auth.token.get('email', '') &&
        request.resource.data.name is string &&
        request.resource.data.status == 'active' &&
        request.resource.data.role == 'user' &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
    }

    function isValidSelfUserUpdate(userId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isActiveOwner(userId) &&
        changed.hasOnly(userUpdateAllowedKeys()) &&
        changed.hasAny(['updatedAt']) &&
        request.resource.data.email is string &&
        request.auth.token.get('email', '') != '' &&
        request.resource.data.email == request.auth.token.get('email', '') &&
        request.resource.data.name is string &&
        request.resource.data.updatedAt == request.time;
    }

    function qnaCreateAllowedKeys() {
      return [
        'userId',
        'userEmail',
        'userName',
        'category',
        'title',
        'content',
        'images',
        'isSecret',
        'status',
        'views',
        'isNotified',
        'createdAt',
        'updatedAt',
        'productId',
        'productName'
      ];
    }

    function qnaCreateRequiredKeys() {
      return [
        'userId',
        'userEmail',
        'userName',
        'category',
        'title',
        'content',
        'images',
        'isSecret',
        'status',
        'views',
        'isNotified',
        'createdAt',
        'updatedAt'
      ];
    }

    function isValidQnACreate() {
      let user = get(userDocument(request.auth.uid)).data;
      return isActiveAccount() &&
        request.resource.data.keys().hasOnly(qnaCreateAllowedKeys()) &&
        request.resource.data.keys().hasAll(qnaCreateRequiredKeys()) &&
        request.resource.data.userId == request.auth.uid &&
        user.email is string &&
        user.name is string &&
        request.resource.data.userEmail is string &&
        request.resource.data.userName is string &&
        request.resource.data.userEmail == user.email &&
        request.auth.token.get('email', '') != '' &&
        user.email == request.auth.token.get('email', '') &&
        request.resource.data.userName == user.name &&
        request.resource.data.category in [
          'product',
          'size',
          'delivery',
          'return',
          'payment',
          'general',
          'other'
        ] &&
        isNonEmptyStringAtMost(request.resource.data.title, 100) &&
        isNonEmptyStringAtMost(request.resource.data.content, 2000) &&
        isValidQnAImages(request.resource.data.images) &&
        request.resource.data.isSecret is bool &&
        request.resource.data.isNotified is bool &&
        isOptionalNonEmptyStringAtMost(request.resource.data, 'productId', 128) &&
        isOptionalNonEmptyStringAtMost(request.resource.data, 'productName', 200) &&
        request.resource.data.status == 'waiting' &&
        request.resource.data.views == 0 &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
    }

    function isValidQnAOwnerUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isActiveOwner(resource.data.userId) &&
        changed.hasOnly([
          'title',
          'content',
          'category',
          'images',
          'isSecret',
          'isNotified',
          'status',
          'updatedAt'
        ]) &&
        isNonEmptyStringAtMost(request.resource.data.title, 100) &&
        isNonEmptyStringAtMost(request.resource.data.content, 2000) &&
        request.resource.data.category in [
          'product',
          'size',
          'delivery',
          'return',
          'payment',
          'general',
          'other'
        ] &&
        isValidQnAImages(request.resource.data.images) &&
        request.resource.data.isSecret is bool &&
        request.resource.data.isNotified is bool &&
        isOptionalNonEmptyStringAtMost(request.resource.data, 'productId', 128) &&
        isOptionalNonEmptyStringAtMost(request.resource.data, 'productName', 200) &&
        request.resource.data.updatedAt == request.time &&
        (!changed.hasAny(['status']) || request.resource.data.status == 'closed');
    }

    function isValidQnAAnswer() {
      let answer = request.resource.data.answer;
      return answer is map &&
        answer.keys().hasOnly([
          'content',
          'answeredBy',
          'answeredAt',
          'isAdmin'
        ]) &&
        answer.keys().hasAll([
          'content',
          'answeredBy',
          'answeredAt',
          'isAdmin'
        ]) &&
        isNonEmptyStringAtMost(answer.content, 2000) &&
        isNonEmptyStringAtMost(answer.answeredBy, 200) &&
        answer.answeredAt == request.time &&
        answer.isAdmin == true;
    }

    function isValidQnAAdminUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isStrictAdmin() &&
        changed.hasOnly(['answer', 'status', 'updatedAt']) &&
        changed.hasAny(['updatedAt']) &&
        request.resource.data.updatedAt == request.time &&
        (!changed.hasAny(['answer']) || isValidQnAAnswer()) &&
        (!changed.hasAny(['status']) ||
          request.resource.data.status in ['waiting', 'answered', 'closed']);
    }

    function inquiryCreateAllowedKeys() {
      return [
        'userId',
        'userEmail',
        'userName',
        'category',
        'title',
        'content',
        'status',
        'createdAt',
        'updatedAt'
      ];
    }

    function isValidInquiryCreate() {
      let user = get(userDocument(request.auth.uid)).data;
      return isActiveAccount() &&
        request.resource.data.keys().hasOnly(inquiryCreateAllowedKeys()) &&
        request.resource.data.keys().hasAll(inquiryCreateAllowedKeys()) &&
        request.resource.data.userId == request.auth.uid &&
        user.email is string &&
        user.name is string &&
        request.resource.data.userEmail is string &&
        request.resource.data.userName is string &&
        request.resource.data.userEmail == user.email &&
        request.auth.token.get('email', '') != '' &&
        user.email == request.auth.token.get('email', '') &&
        request.resource.data.userName == user.name &&
        request.resource.data.category in [
          'order',
          'delivery',
          'exchange',
          'product',
          'account',
          'other'
        ] &&
        isNonEmptyStringAtMost(request.resource.data.title, 100) &&
        isNonEmptyStringAtMost(request.resource.data.content, 2000) &&
        request.resource.data.status == 'waiting' &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
    }

    function isValidInquiryAnswer() {
      let answer = request.resource.data.answer;
      return answer is map &&
        answer.keys().hasOnly(['content', 'answeredBy', 'answeredAt']) &&
        answer.keys().hasAll(['content', 'answeredBy', 'answeredAt']) &&
        isNonEmptyStringAtMost(answer.content, 2000) &&
        isNonEmptyStringAtMost(answer.answeredBy, 200) &&
        answer.answeredAt == request.time;
    }

    function isValidInquiryAdminUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isStrictAdmin() &&
        changed.hasOnly(['answer', 'status', 'updatedAt']) &&
        changed.hasAny(['updatedAt']) &&
        request.resource.data.updatedAt == request.time &&
        (!changed.hasAny(['answer']) || isValidInquiryAnswer()) &&
        (!changed.hasAny(['status']) ||
          request.resource.data.status in ['waiting', 'answered', 'closed']);
    }

    function isValidReviewOwnerUpdate() {
      return isActiveOwner(resource.data.userId) &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.productId == resource.data.productId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'userName',
          'rating',
          'title',
          'content',
          'images',
          'size',
          'color',
          'height',
          'weight',
          'isRecommended',
          'updatedAt'
        ]);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();

      match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categoryOrder/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brandSummaries/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /eventParticipants/{participantId} {
      allow read: if isAdmin() ||
        (isActiveAccount() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mainBanners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /featuredProducts/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /offlineStores/{storeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /offlineServices/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /offlineInfo/{infoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow create: if isValidSelfUserCreate(userId);
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isValidSelfUserUpdate(userId);
      allow delete: if false;

      match /pointHistory/{historyId} {
        allow read: if isActiveOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isActiveOwner(userId) || isAdmin();
      }

      match /recentProducts/{productId} {
        allow read, write: if isActiveOwner(userId) || isAdmin();
      }
    }

    match /carts/{userId} {
      allow read, write: if isActiveOwner(userId) || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() ||
        (isActiveAccount() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if false;
      allow update: if isAdmin() || isValidReviewOwnerUpdate();
      allow delete: if isAdmin() || isActiveOwner(resource.data.userId);
    }

    match /user_coupons/{userCouponId} {
      allow read: if isAdmin() ||
        (isActiveAccount() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    match /userRecentProducts/{docId} {
      allow create: if isAdmin() || isActiveOwner(request.resource.data.userId);
      allow read, delete: if isAdmin() || isActiveOwner(resource.data.userId);
      allow update: if isAdmin() ||
        (isActiveOwner(resource.data.userId) &&
          request.resource.data.userId == resource.data.userId);
    }

    match /userWishlist/{docId} {
      allow create: if isAdmin() || isActiveOwner(request.resource.data.userId);
      allow read, delete: if isAdmin() || isActiveOwner(resource.data.userId);
      allow update: if isAdmin() ||
        (isActiveOwner(resource.data.userId) &&
          request.resource.data.userId == resource.data.userId);
    }

    match /qna/{qnaId} {
      allow create: if isValidQnACreate();
      allow read: if isAdmin() ||
        (isActiveAccount() && resource.data.userId == request.auth.uid);
      allow update: if isValidQnAAdminUpdate() || isValidQnAOwnerUpdate();
      allow delete: if false;
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidInquiryCreate();
      allow read: if isAdmin() ||
        (isActiveAccount() && resource.data.userId == request.auth.uid);
      allow update: if isValidInquiryAdminUpdate();
      allow delete: if false;
    }

    match /coupons/{couponId} {
      allow read: if isActiveAccount();
      allow write: if isAdmin();
    }

    match /migrationRuns/{runId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
